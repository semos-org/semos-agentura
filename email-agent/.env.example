# --- Backend selection (auto-detected if not set) ---
# BACKEND=com          # com, imap, or graph
# EMAIL_ADDRESS=your.email@company.com

# --- Azure AD (for Graph or XOAUTH2 IMAP) ---
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=  # optional, for client credentials flow

# --- IMAP/SMTP (if BACKEND=imap) ---
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587

# --- MS Graph (if BACKEND=graph) ---
# GRAPH_CLIENT_ID=
# GRAPH_TENANT_ID=common

# --- CalDAV (optional calendar integration) ---
# CALDAV_URL=https://caldav.example.com
# CALDAV_USERNAME=
# CALDAV_PASSWORD=
# CALDAV_CALENDAR=

# --- LLM for mailgent agent ---
AZURE_API_KEY=
AZURE_API_BASE=https://your-resource.services.ai.azure.com/anthropic
# MODEL=                # litellm format, e.g. anthropic/claude-sonnet-4-5

# --- Mailgent settings ---
# MAILGENT_TAG=@mailgent
# MAILGENT_AUTO_REPLY=false
# MAILGENT_AUTO_SEND=false

# --- A2A LLM router (optional, enables NL delegation) ---
# ROUTER_LLM_MODEL=
# ROUTER_LLM_API_KEY=
# ROUTER_LLM_API_BASE=
