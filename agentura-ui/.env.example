# Azure AI Foundry (Anthropic endpoint)
AZURE_API_KEY=your-bearer-token
AZURE_API_BASE=https://your-resource.services.ai.azure.com/anthropic

# Agent endpoints (defaults shown)
EMAIL_AGENT_URL=http://localhost:8001/mcp/sse
DOCUMENT_AGENT_URL=http://localhost:8002/mcp/sse
EMAIL_AGENT_BASE=http://localhost:8001
DOCUMENT_AGENT_BASE=http://localhost:8002

# Protocol selection: "mcp" (default, lower latency) or "a2a" (task-based)
# Auto-selection uses MCP tool annotations (readOnlyHint, taskSupport)
# to pick the best protocol per agent. This sets the fallback default.
DEFAULT_PROTOCOL=mcp

# UI server port
# UI_PORT=5006
